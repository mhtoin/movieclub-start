# Version control
.git
.gitignore

# Local environment files — never bake secrets into images
.env
.env.*
!.env.example

# Node dependencies — reinstalled inside the image
node_modules

# Build artifacts — the builder stage produces its own
.output
dist

# Editor and OS noise
.vscode
.idea
*.DS_Store
*.swp
*.swo

# Test and dev tooling
coverage
*.test.ts
*.spec.ts

# Docs
README.md
